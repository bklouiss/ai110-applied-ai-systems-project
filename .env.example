# AlgoAssist Environment Variables
# Copy this file to .env.local and fill in your values before running the application.
#
# Usage:
#   cp .env.example .env.local
#   then edit .env.local with your actual key

# Required for Modes 1, 2, 3, and 4 (Claude API calls).
# Obtain your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here
