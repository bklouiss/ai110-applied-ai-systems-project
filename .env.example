# AlgoAssist Environment Variables
# Copy this file to .env and fill in your values before running the application.
#
# Usage:
#   cp .env.example .env
#   then edit .env with your actual key

# Required for Modes 1, 3, and 4 (Claude API calls).
# Mode 2 (RAG Retrieval Only) works without this key.
# Obtain your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here
